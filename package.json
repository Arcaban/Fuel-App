{
  "name": "fuel-decision-routing-assistant",
  "version": "1.0.0",
  "description": "An application to assist with fuel decision making and routing.",
  "main": "src/app.ts",
  "scripts": {
    "start": "ts-node src/app.ts",
    "start:api": "ts-node src/app.ts",
    "start:client": "http-server client -p 3000 --cors -c-1 -o",
    "dev": "concurrently \"npm run start:api\" \"npm run start:client\"",
    "build": "tsc",
    "test": "jest",
    "import-stations": "ts-node scripts/import-stations.ts"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^27.0.0",
    "@types/node": "^16.18.126",
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1",
    "jest": "^27.0.0",
    "ts-jest": "^27.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^4.9.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.spec.ts"]
  },
  "keywords": [
    "fuel",
    "routing",
    "decision",
    "assistant"
  ],
  "author": "Your Name",
  "license": "MIT"
}
