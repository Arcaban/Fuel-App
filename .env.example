# tanq. Backend — environment variables
# Copy this file to .env and fill in values for local development.
# In Railway, set these in the service's Variables tab.

# Server
PORT=3001
NODE_ENV=production

# Data provider: 'dgeg' for live data, 'mock' for local testing
FUEL_DATA_PROVIDER=dgeg

# DGEG public API (no auth required — do not change)
FUEL_PRICE_API_URL=https://precoscombustiveis.dgeg.gov.pt/api/PrecoComb

# Max stations returned per DGEG request (56 is the API page limit)
DGEG_MAX_STATIONS=56
