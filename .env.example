# Server
PORT=3001
NODE_ENV=development

# Fuel prices: "dgeg" (official Portugal data) or "mock" (local test data)
FUEL_DATA_PROVIDER=dgeg

# Max stations to fetch detailed prices for per request (DGEG rate limiting)
DGEG_MAX_STATIONS=56

# Optional future integrations
DATABASE_URL=your_database_url_here
API_KEY=your_api_key_here
MAPS_API_URL=your_maps_api_url_here
